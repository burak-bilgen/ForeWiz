    "instruction_blizzard": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay inside. If you must go out, wear multiple layers and cover exposed skin. Carry emergency supplies."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mümkünse dışarı çıkmayın. Çıkmanız gerekiyorsa kat kat giyinip açıkta kalan cildinizi kapatın. Acil durum malzemeleri bulundurun."
          }
        }
      }
    },
    "instruction_cold": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wear layers, cover all exposed skin, and limit time outdoors. Watch for signs of hypothermia."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kat kat giyin, açıkta kalan cildinizi koruyun. Dışarıda geçirdiğiniz süreyi sınırlayın."
          }
        }
      }
    },
    "instruction_flashFlood": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move to higher ground immediately. Never drive through flood water. Avoid low-lying areas."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yüksek yerlere çıkın. Asla sel sularına girmeyin. Alçak bölgelerden uzak durun."
          }
        }
      }
    },
    "instruction_fog": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drive slowly with low beams on. Keep plenty of distance from the car ahead. Avoid sudden stops."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Farlarınızı yakın ve yavaş sürün. Öndeki araçla mesafenizi koruyun. Ani duruşlardan kaçının."
          }
        }
      }
    },
    "instruction_hail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay indoors and away from windows. Move vehicles under cover if you can do so safely."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Korumalı bir alana geçin ve pencerelerden uzak durun. Güvenliyse aracınızı kapalı bir alana çekin."
          }
        }
      }
    },
    "instruction_heat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay hydrated, avoid direct sun during peak hours, and never leave kids or pets in parked cars."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bol su için, serin bir yerde kalın, güneşten korunun. Arabanızda çocuk veya evcil hayvan bırakmayın."
          }
        }
      }
    },
    "instruction_storm": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay indoors and away from windows. Avoid using plumbing and electrical appliances until the storm passes."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İçeride kalın ve camlardan uzak durun. Fırtına geçene kadar elektronik aletleri kullanmaktan kaçının."
          }
        }
      }
    },
    "instruction_tornado": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move to a basement or interior room on the lowest floor. Stay away from windows. If outside, lie flat in a ditch."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hemen güvenli bir alana geçin. Bodrum katına veya iç odalara sığının. Pencerelerden uzak durun."
          }
        }
      }
    },
    "instruction_wind": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Secure loose objects outside. Be careful around trees and power lines. Driving may be difficult."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Açık alanlardan ve ağaç altlarından uzak durun. Dışarıdaki gevşek nesneleri sabitleyin."
          }
        }
      }
    },
    "keeping_outdoor_time_short_is": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "shorter outdoor time is the safer call."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dışarıda kısa süre kalmanızı öneririm."
          }
        }
      }
    },
