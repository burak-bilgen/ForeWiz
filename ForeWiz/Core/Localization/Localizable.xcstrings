    "recommendation_explain_activity": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Activity compatibility affects how comfortable your planned exercise feels."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivite uyumu, planlanan egzersizin ne kadar rahat hissettireceğini etkiler."
          }
        }
      }
    },
    "recommendation_explain_default": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Weather conditions are balanced for most activities today."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hava koşulları bugün çoğu aktivite için dengeli."
          }
        }
      }
    },
    "recommendation_explain_precip": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Precipitation can disrupt outdoor plans and affect comfort."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yağış, dış mekan planlarını bozabilir ve konforu etkileyebilir."
          }
        }
      }
    },
    "recommendation_explain_schedule": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Timing your outing right makes a big difference in comfort."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Çıkış saatini iyi ayarlamak konforu büyük ölçüde etkiler."
          }
        }
      }
    },
    "recommendation_explain_temp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Temperature plays a key role in how comfortable you will feel outside."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sıcaklık, dışarıda ne kadar rahat hissedeceğinizde kilit rol oynar."
          }
        }
      }
    },
    "recommendation_explain_uv": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "UV levels affect skin safety and comfort during outdoor time."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "UV seviyeleri, dışarıda geçirilen sürede cilt sağlığını ve konforu etkiler."
          }
        }
      }
    },
    "recommendation_explain_wind": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wind can make a pleasant day feel cooler and affect outdoor plans."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rüzgâr, güzel bir günü serin hissettirebilir ve planları etkileyebilir."
          }
        }
      }
    },
