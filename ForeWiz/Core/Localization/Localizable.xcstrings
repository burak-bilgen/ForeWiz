    "wizpath_rec_extreme_heat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extreme heat. Stay hydrated, use air conditioning, and avoid prolonged exposure. Check on vulnerable passengers."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aşırı sıcaklık uyarısı. Bol bol su tüketin, araç klimasını çalıştırın ve sıcağa uzun süre maruz kalmaktan kaçının. Hassas durumdaki yolcuları sık sık kontrol edin."
          }
        }
      }
    },
    "wizpath_rec_fog": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use low-beam headlights and reduce speed significantly. Increase following distance. Pull over if visibility drops too low."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kısa farları yakın ve hızınızı önemli ölçüde azaltın. Öndeki araçla arabanızı iyi mesafe bırakın, ani duruşlardan kaçının."
          }
        }
      }
    },
    "wizpath_rec_freezing": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Freezing temperatures. Watch for black ice on roads. Dress warmly and limit exposure."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Donma seviyesinde sıcaklıklar. Yollardaki gizli buzlanmaya karşı dikkatli olun. Kalın giyinin ve dışarıda kalma sürenizi sınırlayın."
          }
        }
      }
    },
    "wizpath_rec_heavy_rain": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reduce speed and increase following distance. Watch for standing water on roads. Consider delaying travel."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hızınızı azaltın ve takip mesafenizi artırın. Yoldaki su birikintilerine karşı dikkatli olun. Mümkünse seyahatinizi ertelemeyi düşünebilirsiniz."
          }
        }
      }
    },
    "wizpath_rec_high_temp": {
      "comment": "WizPath: recommendation to stop due to high temperature (format: %d for Celsius)",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "High temperature (%d°C) — stop for hydration and cooling."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yüksek sıcaklık (%d°C) — su içmek ve serinlemek için mola verin."
          }
        }
      }
    },
    "wizpath_rec_high_wind": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "High winds detected. Hold the steering wheel firmly. Watch for debris on the road. Consider delaying travel."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kuvvetli rüzgâr tespit edildi. Direksiyonu iki elinizle sıkı tutun. Yola düşebilecek parçalara dikkat edin; seyahatinizi ertelemeyi düşünebilirsiniz."
          }
        }
      }
    },
    "wizpath_rec_normal": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Conditions are normal. Drive safely and enjoy your journey."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hava koşulları normal. Keyifli yolculuklar!"
          }
        }
      }
    },
    "wizpath_rec_rain": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drive carefully. Wet roads may be slippery. Allow extra braking distance."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lütfen dikkatli sürün; ıslak yollar kaygan olabilir. Önlem olarak takip mesafenizi ve fren mesafenizi artırın."
          }
        }
      }
    },
    "wizpath_rec_rain_break": {
      "comment": "WizPath: recommendation to take a dry break during rain",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rain at this stop — take a dry break before continuing."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu mola yerinde yağış var — yolculuğa devam etmeden önce kapalı bir alanda dinlenebilirsiniz."
          }
        }
      }
    },
    "wizpath_rec_severe_shelter": {
      "comment": "WizPath: recommendation to find shelter during severe weather",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find shelter — severe weather expected."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kapalı ve korunaklı bir alana geçin — şiddetli hava koşulları bekleniyor."
          }
        }
      }
    },
    "wizpath_rec_severe_wait": {
      "comment": "WizPath: recommendation to wait out severe weather",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Severe weather — wait for conditions to improve."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Şiddetli hava koşulları var — yola çıkmak için havanın düzelmesini bekleyin."
          }
        }
      }
    },
    "wizpath_rec_snow": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drive with extreme caution. Ensure proper tires and slow down. Allow extra time for your journey."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lütfen son derece dikkatli sürün. Kış lastiklerinizin takılı olduğundan emin olun ve hızınızı düşürün. Yolculuk sürenizi esnek tutun."
          }
        }
      }
    },
    "wizpath_rec_strong_wind_stop": {
      "comment": "WizPath: recommendation to stop due to strong winds (cycling/walking)",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Strong winds expected — ideal stop to catch your breath and find wind shadow."
