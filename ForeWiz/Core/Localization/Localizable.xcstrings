          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kıyafet Önerisi"
          }
        }
      }
    },
    "outfit_accessories_format": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don't forget: %1$@"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@"
          }
        }
      }
    },
    "outfit_advice_cold": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's cold! A warm coat, sweater, and closed shoes are a must. Layer up — you can always take off if needed."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bugün hava soğuk, kalın giyinmeyi unutma."
          }
        }
      }
    },
    "outfit_advice_cool": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's a bit cool out. A sweater or hoodie with closed shoes will keep you cozy. A light scarf wouldn't hurt."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dışarısı biraz serin. Bir kazak veya hoodie ile kapalı ayakkabı rahat ettirir. Hafif bir atkı da fena olmaz."
          }
        }
      }
    },
    "outfit_advice_evening_layer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It'll cool down significantly in the evening — take a light jacket or sweater if you plan to be out late."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Akşama doğru hava belirgin şekilde soğuyacak — geç saatlere kadar dışarıda kalacaksan yanına bir hırka veya ceket al."
          }
        }
      }
    },
    "outfit_advice_extreme_hot": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's scorching out there! A light t-shirt and shorts will keep you cool. Don't forget water and sun protection."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aşırı sıcak! İnce, açık renkli giysiler giy ve bol su iç."
          }
        }
      }
    },
    "outfit_advice_extreme_humid": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extreme heat with high humidity — a light, breathable shirt and shorts are your best bet. Stay in the shade if you can."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aşırı sıcak ve yüksek nem — hafif, nefes alabilen bir tişört ve şort en iyi tercihin. Mümkünse gölgede kal."
          }
        }
      }
    },
    "outfit_advice_freezing": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Freezing out there! A winter coat, thermal layers, gloves, and a hat are essential. Keep your outings short."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dışarısı dondurucu! Kışlık mont, termal katmanlar, eldiven ve bere şart. Dışarıda fazla kalma."
          }
        }
      }
    },
    "outfit_advice_hot": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's a warm one! A t-shirt and light pants are perfect. If you're heading out for a while, bring some water."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hava sıcak, hafif ve rahat giysiler tercih et."
          }
        }
      }
    },
    "outfit_advice_hot_humid": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hot and humid — go for lightweight, breathable fabrics. A cotton t-shirt and shorts will keep you comfortable."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sıcak ve nemli — hafif, nefes alabilen kumaşlar tercih et. Pamuklu bir tişört ve şort rahat ettirir."
          }
        }
      }
    },
    "outfit_advice_humid_fabric": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's humid out — go for loose, cotton or linen fabrics. They'll help you stay cool and avoid that sticky feeling."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nemli bir hava — bol, pamuklu veya keten kumaşlar tercih et. Serin kalmana ve o yapış yapış hissi önlemene yardımcı olur."
          }
        }
      }
    },
    "outfit_advice_layer_swing": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Big temperature swing today — start with layers in the morning so you can peel them off by midday."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bugün büyük bir sıcaklık farkı var — sabah katmanlı giyin ki öğlene doğru üstünü çıkarabilesin."
          }
        }
      }
    },
    "outfit_advice_mild": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mild and comfortable — a t-shirt with a light jacket or cardigan works great. You'll be glad you have the extra layer later."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ilık ve rahat — tişörtün üzerine hafif bir ceket veya hırka ideal. Fazladan katmanın olduğu için sonra memnun kalacaksın."
          }
        }
      }
    },
    "outfit_advice_rain": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rain is in the forecast — grab a rain jacket or umbrella. Waterproof shoes will save your day."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yağmur bekleniyor, yanına şemsiye al."
          }
        }
      }
    },
    "outfit_advice_sun_protection": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The sun is strong today — wear a hat, sunglasses, and don't skip the sunscreen. Your skin will thank you."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bugün güneş çok güçlü — şapka, güneş gözlüğü tak ve güneş kremini ihmal etme. Cildin sana teşekkür edecek."
          }
        }
      }
    },
    "outfit_advice_warm": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pleasantly warm! A t-shirt and casual pants are all you need. Perfect weather for a stroll."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Keyifli bir sıcaklık! Tişört ve rahat bir pantolon yeterli. Yürüyüş için harika bir hava."
          }
        }
      }
    },
    "outfit_advice_warm_humid": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warm and a bit muggy — a breathable top and light pants will do the trick. You might feel sticky by midday."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ilık ve biraz bunaltıcı — nefes alabilen bir üst ve hafif pantolon iş görür. Öğlene doğru yapış yapış olabilirsin."
          }
        }
      }
    },
    "outfit_advice_wind": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Windy out there! A windbreaker or a tightly woven jacket will help. Watch out for gusts if you're cycling."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rüzgârlı bir gün! Rüzgârlık veya sıkı dokulu bir ceket iş görür. Bisiklet kullanıyorsan ani rüzgârlara dikkat."
          }
        }
      }
    },
