          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bugün dışarısı oldukça soğuk! Kalın bir mont, kazak ve kapalı ayakkabılar tercih etmelisiniz. Kat kat giyinerek gün içinde sıcaklığa göre ayarlama yapabilirsiniz."
          }
        }
      }
    },
    "outfit_advice_cool": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's a bit cool out. A sweater or hoodie with closed shoes will keep you cozy. A light scarf wouldn't hurt."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dışarısı biraz serin görünüyor. Bir kazak veya kapüşonlu üst ile kapalı ayakkabılar sizi sıcak tutacaktır. Hafif bir atkı takmak da konforunuzu artırabilir."
          }
        }
      }
    },
    "outfit_advice_evening_layer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It'll cool down significantly in the evening - take a light jacket or sweater if you plan to be out late."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Akşama doğru sıcaklıklar belirgin şekilde düşecek. Geç saatlere kadar dışarıda kalacaksanız yanınıza mutlaka bir ceket veya hırka alın."
          }
        }
      }
    },
    "outfit_advice_extreme_hot": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's scorching out there! A light t-shirt and shorts will keep you cool. Don't forget water and sun protection."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kavurucu bir sıcak var! İnce tişört ve şort en doğru tercih. Mutlaka yanınızda su bulundurun ve güneşten korunmayı ihmal etmeyin."
          }
        }
      }
    },
    "outfit_advice_extreme_humid": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extreme heat with high humidity - a light, breathable shirt and shorts are your best bet. Stay in the shade if you can."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aşırı sıcak ve nemli hava var — hafif, nefes alabilen kumaşlar ve şort en iyi tercih. Mümkünse gölgede kalın."
          }
        }
      }
    },
    "outfit_advice_freezing": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Freezing out there! A winter coat, thermal layers, gloves, and a hat are essential. Keep your outings short."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dışarısı dondurucu derecede soğuk! Kalın bir kışlık mont, termal içlikler, eldiven ve bere bugün olmazsa olmazınız. Dışarıda geçireceğiniz süreyi olabildiğince kısa tutmaya çalışın."
          }
        }
      }
    },
    "outfit_advice_hot": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's a warm one! A t-shirt and light pants are perfect. If you're heading out for a while, bring some water."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sıcak bir gün sizi bekliyor! Tişört ve hafif bir pantolon oldukça konforlu olacaktır. Dışarıda uzun süre kalacaksanız yanınızda su bulundurun."
          }
        }
      }
    },
    "outfit_advice_hot_humid": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hot and humid - go for lightweight, breathable fabrics. A cotton t-shirt and shorts will keep you comfortable."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sıcak ve nemli — hafif, nefes alabilen kumaşlar tercih edin. Pamuklu bir tişört ve şort rahat ettirir."
          }
        }
      }
    },
    "outfit_advice_humid_fabric": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's humid out - go for loose, cotton or linen fabrics. They'll help you stay cool and avoid that sticky feeling."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nemli hava var — bol, pamuklu veya keten kumaşlar tercih edin. Serinlemenize ve yapışkan hissi önlemenize yardımcı olur."
          }
        }
      }
    },
    "outfit_advice_layer_swing": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Big temperature swing today - start with layers in the morning so you can peel them off by midday."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bugün gün içinde ciddi sıcaklık değişimleri yaşanacak; sabah kat kat giyinirseniz öğlene doğru havanın ısınmasıyla üzerinizdekileri kolayca ayarlayabilirsiniz."
          }
        }
      }
    },
    "outfit_advice_mild": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mild and comfortable - a t-shirt with a light jacket or cardigan works great. You'll be glad you have the extra layer later."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hava oldukça ılık ve konforlu; tişörtünüzün üzerine hafif bir ceket veya hırka almanız harika bir çözüm olacaktır. Günün ilerleyen saatlerinde bu önleminiz için kendinize teşekkür edeceksiniz."
          }
        }
      }
    },
    "outfit_advice_rain": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rain is in the forecast - grab a rain jacket or umbrella. Waterproof shoes will save your day."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tahminlerde yağış görünüyor; yanınıza mutlaka bir yağmurluk veya şemsiye almalısınız. Su geçirmeyen ayakkabılar da gününüzü kurtarabilir."
          }
        }
      }
    },
    "outfit_advice_sun_protection": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The sun is strong today - wear a hat, sunglasses, and don't skip the sunscreen. Your skin will thank you."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Güneş ışınları bugün oldukça güçlü; şapka ve güneş gözlüğü takın, güneş kremini sürün. Mümkünse gölgede kalın."
          }
        }
      }
    },
    "outfit_advice_warm": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pleasantly warm! A t-shirt and casual pants are all you need. Perfect weather for a stroll."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oldukça keyifli, ılık bir hava! Yalnızca bir tişört ve rahat bir pantolon yeterli olacaktır. Dışarıda yürüyüş yapmak için mükemmel bir zaman."
          }
        }
      }
    },
    "outfit_advice_warm_humid": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warm and a bit muggy - a breathable top and light pants will do the trick. You might feel sticky by midday."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ilık ama biraz bunaltıcı — nefes alabilen bir üst ve hafif pantolon iş görür. Öğle saatlerinde yapış yapış hissedebilirsiniz."
          }
        }
      }
    },
    "outfit_advice_wind": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Windy out there! A windbreaker or a tightly woven jacket will help. Watch out for gusts if you're cycling."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dışarısı epey rüzgârlı! Bir rüzgârlık veya sıkı dokunmuş bir ceket çok faydalı olacaktır. Eğer bisiklet kullanacaksanız ani rüzgâr hamlelerine karşı dikkatli olmalısınız."
          }
        }
      }
    },
