      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rain reduces tire grip. Reduce speed and avoid sudden braking."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yağmur lastik tutuşunu azaltır. Hızınızı düşürün ve ani fren yapmaktan kaçının."
          }
        }
      }
    },
