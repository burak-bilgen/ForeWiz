      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@: %2$lld out of %3$lld, %4$@"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@: %2$lld/%3$lld, %4$@"
          }
        }
      }
    },
