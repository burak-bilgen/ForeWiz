    "instruction_blizzard": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay inside. If you must go out, wear multiple layers and cover exposed skin. Carry emergency supplies."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İçeride kal. Çıkmak zorundaysan kat kat giyin, açık cildini kapat. Acil durum malzemesi taşı."
          }
        }
      }
    },
    "instruction_cold": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wear layers, cover all exposed skin, and limit time outdoors. Watch for signs of hypothermia."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kat kat giyin, açık cildini tamamen kapat ve dışarıda geçirdiğin süreyi sınırla. Hipotermi belirtilerine dikkat et."
          }
        }
      }
    },
    "instruction_flashFlood": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move to higher ground immediately. Never drive through flood water. Avoid low-lying areas."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hemen yüksek bir yere çık. Sel suyunda asla araç kullanma. Alçak bölgelerden uzak dur."
          }
        }
      }
    },
    "instruction_fog": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drive slowly with low beams on. Keep plenty of distance from the car ahead. Avoid sudden stops."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yavaş ve kısa farlarla sür. Öndeki araçla bol mesafe bırak. Ani duruşlardan kaçın."
          }
        }
      }
    },
    "instruction_hail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay indoors and away from windows. Move vehicles under cover if you can do so safely."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İçeride ve pencerelerden uzak dur. Güvenli bir şekilde yapabiliyorsan aracını kapalı alana çek."
          }
        }
      }
    },
    "instruction_heat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay hydrated, avoid direct sun during peak hours, and never leave kids or pets in parked cars."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bol su iç, öğle saatlerinde direkt güneşten kaçın ve çocukları ya da hayvanları park halindeki arabada asla bırakma."
          }
        }
      }
    },
    "instruction_storm": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay indoors and away from windows. Avoid using plumbing and electrical appliances until the storm passes."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İçeride kal, pencerelerden uzak dur. Fırtına geçene kadar tesisat ve elektrikli alet kullanma."
          }
        }
      }
    },
    "instruction_tornado": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move to a basement or interior room on the lowest floor. Stay away from windows. If outside, lie flat in a ditch."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "En alt katta, penceresiz bir iç odada veya bodrumda korun. Dışarıdaysan düz bir hendeğe yat."
          }
        }
      }
    },
    "instruction_wind": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Secure loose objects outside. Be careful around trees and power lines. Driving may be difficult."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dışarıdaki gevşek eşyaları sabitle. Ağaçların ve elektrik hatlarının yakınında dikkatli ol. Araç kullanmak zor olabilir."
          }
        }
      }
    },
    "it_is_safer_to_keep": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you can, keep outdoor time short today."
