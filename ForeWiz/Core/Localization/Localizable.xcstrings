    "instruction_blizzard": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay inside. If you must go out, wear multiple layers and cover exposed skin. Carry emergency supplies."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mümkünse dışarı çıkma. Çıkman gerekiyorsa kat kat giyin."
          }
        }
      }
    },
    "instruction_cold": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wear layers, cover all exposed skin, and limit time outdoors. Watch for signs of hypothermia."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kat kat giyin, açıkta kalan cildini koru."
          }
        }
      }
    },
    "instruction_flashFlood": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move to higher ground immediately. Never drive through flood water. Avoid low-lying areas."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yüksek yerlere çık. Asla sel sularına girme."
          }
        }
      }
    },
    "instruction_fog": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drive slowly with low beams on. Keep plenty of distance from the car ahead. Avoid sudden stops."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Farlarını yak ve yavaş sür. Görüş mesafesi çok düşük."
          }
        }
      }
    },
    "instruction_hail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay indoors and away from windows. Move vehicles under cover if you can do so safely."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Korumalı bir alana geç. Araba kullanıyorsan güvenli bir yerde dur."
          }
        }
      }
    },
    "instruction_heat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay hydrated, avoid direct sun during peak hours, and never leave kids or pets in parked cars."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bol su iç, serin bir yerde kal ve güneşten kaçın."
          }
        }
      }
    },
    "instruction_storm": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay indoors and away from windows. Avoid using plumbing and electrical appliances until the storm passes."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İçeride kal ve camlardan uzak dur."
          }
        }
      }
    },
    "instruction_tornado": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move to a basement or interior room on the lowest floor. Stay away from windows. If outside, lie flat in a ditch."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hemen güvenli bir alana geç. Bodrum katına veya iç odalara sığın."
          }
        }
      }
    },
    "instruction_wind": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Secure loose objects outside. Be careful around trees and power lines. Driving may be difficult."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Açık alanlardan ve ağaç altlarından uzak dur."
          }
        }
      }
    },
    "keeping_outdoor_time_short_is": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "shorter outdoor time is the safer call."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dışarıda kısa süre kalmanı öneririm."
          }
        }
      }
    },
